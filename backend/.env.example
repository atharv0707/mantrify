# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_random_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_random_chars

# SMTP — leave blank to log emails to the console (dev mode)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@mantrify.app

# Google OAuth Web/iOS/Android client IDs from console.cloud.google.com
GOOGLE_CLIENT_ID=

APP_NAME=Mantrify
BASE_URL=http://localhost:4000
